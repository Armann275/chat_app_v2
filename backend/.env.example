NODE_ENV=development
PORT=3010

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=chat_app

JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

LOG_LEVEL=info
CORS_ORIGIN=http://localhost:5173

# SMTP for verification emails. Leave blank in dev to use an Ethereal test
# account (the preview URL is logged after each send).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@chat-app.local

# Google Gemini (free tier — get a key at https://aistudio.google.com/apikey)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# How many recent messages to include as conversation history per AI call.
AI_HISTORY_MAX_MESSAGES=20
